# OpenMemory API — Environment Variables
# Copy to .env:  cp .env.example .env

# === User ===
USER=steven

# === Ollama — where is it running? ===
# host machine (Docker Desktop):  http://host.docker.internal:11434
# Ollama in same compose stack:    http://ollama:11434
# Remote machine:                  http://192.168.x.x:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# === LLM (fact & entity extraction via Ollama) ===
LLM_PROVIDER=ollama
LLM_MODEL=qwen3.5:4b

# === Embeddings (via Ollama) ===
EMBEDDER_PROVIDER=ollama
EMBEDDER_MODEL=qwen3-embedding:0.6b
EMBEDDER_OLLAMA_BASE_URL=http://host.docker.internal:11434

# === Vector Store (Qdrant) ===
VECTOR_STORE_PROVIDER=qdrant
QDRANT_HOST=mem0_store
QDRANT_PORT=6333
QDRANT_COLLECTION=openmemory
QDRANT_EMBEDDING_DIMS=1024

# === Graph Store (Neo4j) ===
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=openmemory

# === Memory Mode ===
# advanced = hybrid search (vector+graph+temporal), smart add with dedup, smart delete with related
# simple   = basic mem0 (SQLite text search, raw add, simple delete)
MEMORY_MODE=advanced

# === LLM Fact Review ===
LLM_FACT_REVIEW=true

# === Session Context ===
SESSION_CONTEXT=true

# === Memory Brain Agent ===
# Uses LLM_MODEL + OLLAMA_BASE_URL (same model for extraction and agent)
BRAIN_MAX_STEPS=12

# === Database ===
# DATABASE_URL=sqlite:///./db/openmemory.db
